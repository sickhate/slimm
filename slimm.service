[Unit]
Description=SLiMM — stateless DRM/KMS login bootstrapper
Documentation=https://github.com/sickhate/slimm
DefaultDependencies=no
After=systemd-user-sessions.service
Before=graphical.target
Conflicts=getty@tty1.service

[Service]
ExecStart=/usr/bin/slimm
Type=simple
StandardInput=tty
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=1
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
UtmpIdentifier=tty1

[Install]
WantedBy=graphical.target
